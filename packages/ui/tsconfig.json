{
  "compilerOptions": {
    "outDir": "dist",
    "esModuleInterop": true,
    "lib": ["es2021", "dom"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noImplicitAny": true,
    "sourceMap": true,
    "strict": true,
    "jsx": "react-jsx",
    "target": "es2021",
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "declaration": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["**/*.ts", "**/*.mts", "**/*.tsx", "./typings/*.d.ts", ""],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.spec.tsx", "src/test"]
}
