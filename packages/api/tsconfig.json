{
  "compilerOptions": {
    "outDir": "dist",
    "esModuleInterop": true,
    "lib": ["es2019"],
    "module": "CommonJS",
    "rootDir": "./src",
    "noImplicitAny": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2019",
    "noUnusedParameters": true,
    "noUnusedLocals": true,
    "resolveJsonModule": true,
    "declaration": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["./src", "./typings/*.ts"]
}
